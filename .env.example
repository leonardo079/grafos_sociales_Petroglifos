# === PostgreSQL + pgvector (Supabase) ===
# Copiar los valores del .env del proyecto principal BackendPetroglifos
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# === Similarity thresholds ===
IMAGE_TOP_K=5
IMAGE_MIN_SIMILARITY=0.60
EDGE_MIN_SIMILARITY=0.70

# === App ===
ENV=development
LOG_LEVEL=INFO
